<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#84ff9f"
    tools:context=".GameActivity">

    <!-- Guideline to position content after symbol buttons -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topContentGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="250dp" />

    <!-- Points Icon -->
    <TextView
        android:id="@+id/pointsNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/points_icon"
        android:fontFamily="@font/atop"
        android:text="0"
        android:textColor="#edff8f"
        android:textSize="35dp"
        android:shadowColor="#000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="1"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Streak Icon -->
    <TextView
        android:id="@+id/streakRecordNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/streak_record_icon"
        android:fontFamily="@font/atop"
        android:text="0"
        android:textColor="#edff8f"
        android:textSize="35dp"
        android:shadowColor="#000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="1"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/gameSiteTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:visibility="visible"
        android:fontFamily="@font/atop"
        android:text="CHOOSE A SYMBOL TO PLAY"
        android:textColor="@color/black"
        android:textSize="25sp"
        app:layout_constraintTop_toBottomOf="@id/pointsNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Symbol Buttons -->
    <LinearLayout
        android:id="@+id/symbolButtons"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="22dp"
        app:layout_constraintTop_toBottomOf="@id/gameSiteTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <Button
                android:id="@+id/additionButton"
                android:layout_width="280dp"
                android:layout_height="135dp"
                android:layout_margin="8dp"
                android:layout_gravity="center"
                android:visibility="visible"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/atop"
                android:text="+"
                android:textColor="@color/black"
                android:textSize="70sp" />

            <Button
                android:id="@+id/subtractionButton"
                android:layout_width="280dp"
                android:layout_height="135dp"
                android:layout_margin="8dp"
                android:visibility="visible"
                android:layout_gravity="center"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/atop"
                android:text="-"
                android:textColor="@color/black"
                android:textSize="70sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/multiplicationButton"
                android:layout_width="280dp"
                android:layout_height="135dp"
                android:layout_margin="8dp"
                android:visibility="visible"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/atop"
                android:layout_gravity="center"
                android:text="*"
                android:textColor="@color/black"
                android:textSize="70sp" />

            <Button
                android:id="@+id/divisionButton"
                android:layout_width="280dp"
                android:layout_height="135dp"
                android:layout_margin="8dp"
                android:visibility="visible"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/atop"
                android:layout_gravity="center"
                android:text="÷"
                android:textColor="@color/black"
                android:textSize="70sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Math Expression -->
    <TextView
        android:id="@+id/mathExpressionBackground"
        android:layout_width="304dp"
        android:layout_height="48dp"
        android:background="@color/white"
        android:textColor="@color/black"
        android:gravity="center"
        android:textSize="35dp"
        android:visibility="gone"
        android:fontFamily="@font/beachday"
        android:inputType="number"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="@id/topContentGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Answer Buttons -->
    <LinearLayout
        android:id="@+id/answerButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/mathExpressionBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/choiceOne"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:visibility="gone"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/beachday"
                android:text="5"
                android:textColor="@color/black"
                android:textSize="40sp" />

            <Button
                android:id="@+id/choiceThree"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:visibility="gone"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/beachday"
                android:text="8"
                android:textColor="@color/black"
                android:textSize="40sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/choiceTwo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:visibility="gone"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/beachday"
                android:text="4"
                android:textColor="@color/black"
                android:textSize="40sp" />

            <Button
                android:id="@+id/choiceFour"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:visibility="gone"
                android:background="@drawable/rounded_button"
                android:fontFamily="@font/beachday"
                android:text="19"
                android:textColor="@color/black"
                android:textSize="40sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress Bar -->

    <!-- Restart Button -->

    <ProgressBar
        android:id="@+id/timeBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="288dp"
        android:layout_height="16dp"
        android:layout_marginTop="108dp"
        android:max="100"
        android:progress="0"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/gameSiteTitle" />

    <Button
        android:id="@+id/restartGameButton"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:layout_marginStart="52dp"
        android:layout_marginBottom="72dp"
        android:background="@drawable/rounded_button"
        android:drawablePadding="-2dp"
        android:fontFamily="@font/atop"
        android:gravity="center"
        android:text="Restart"
        android:textColor="@color/black"
        android:textSize="18dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Next Expression Button -->
    <Button
        android:id="@+id/newExpressionButton"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:layout_marginBottom="72dp"
        android:background="@drawable/rounded_button"
        android:drawableRight="@drawable/next_expression_arrow"
        android:drawablePadding="-10dp"
        android:fontFamily="@font/atop"
        android:text="next"
        android:textColor="@color/black"
        android:textSize="19dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="0.829" />

</androidx.constraintlayout.widget.ConstraintLayout>
